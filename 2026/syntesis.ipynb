    "rz3 = Rz_gate(3)  # crea il kernel fuori da squin\n",
    "\n",
    "@squin.kernel\n",
    "def test_rz():\n",
    "    qubits = squin.qalloc(1)\n",
    "    rz3(qubits[0])\n",
    "\n",
    "tsim.Circuit(test_rz).diagram(width=1200)"
   ]
