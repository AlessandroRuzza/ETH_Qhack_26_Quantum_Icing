   "source": [
    "N_VALUES = range(8)\n",
    "PART2_EPSILON = 1e-4\n",
    "\n",
    "part2_circuits = {}\n",
    "part2_sequences = {}\n",
    "\n",
    "for n in N_VALUES:\n",
    "    theta = np.pi / (2 ** n)\n",
    "    circ = gridsynth_rz(theta, epsilon=PART2_EPSILON)\n",
    "    sequence = gate_sequence_from_circuit(circ)\n",
    "\n",
    "    part2_circuits[n] = circ\n",
    "    part2_sequences[n] = sequence\n",
    "\n",
    "print(\"Part 2 synthesized circuits\")\n",
    "for n in N_VALUES:\n",
    "    circ = part2_circuits[n]\n",
    "    print(\n",
    "        f\"n={n}: gates={len(sequence)}, \"\n",
    "        f\"T-count={t_count_from_sequence(sequence)}, \"\n",
    "        f\"ops={dict(circ.count_ops())}\"\n",
    "    )\n",
    "\n",
    "# Keep the n=3 circuit visible as the reference example.\n",
    "circ = part2_circuits[3]\n",
    "print(\"\\nExample circuit for n=3, Rz(pi/8):\")\n",
    "print(circ)\n",
    "print(circ.count_ops())\n",
    "print(\"T-count:\", t_count_from_sequence(part2_sequences[3]))"
   ]
