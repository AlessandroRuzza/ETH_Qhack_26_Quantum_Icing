    "# ============================================================\n",
    "# Team Synthesis - Part 3\n",
    "# Benchmark of injected-T implementation\n",
    "# ============================================================\n",
    "\n",
    "import os, sys, importlib\n",
    "sys.path.insert(0, os.path.dirname(os.path.abspath(\"syntesis_part3.py\")))\n",
    "\n",
    "import syntesis_part3\n",
    "importlib.reload(syntesis_part3)\n",
    "\n",
    "part3_results = syntesis_part3.run_part3_analysis(\n",
    "    part2_circuits=globals().get(\"part2_circuits\"),\n",
    "    part2_sequences=globals().get(\"part2_sequences\"),\n",
    "    n_values=globals().get(\"N_VALUES\", range(51)),\n",
    "    part2_epsilon=globals().get(\"PART2_EPSILON\", 1e-10),\n",
    "    results_dir=globals().get(\"RESULTS_DIR\", \"results\"),\n",
    "    display_fn=display,\n",
    ")\n",
    "\n",
    "df_part3 = part3_results[\"df_part3\"]\n",
    "part2_circuits = part3_results[\"part2_circuits\"]\n",
    "part2_sequences = part3_results[\"part2_sequences\"]\n"
=======
    "    t_count = t_count_from_sequence(sequence)\n",
    "    clifford_count = len(sequence) - t_count\n",
    "    print(f\"n={n}: T-count={t_count}, Clifford-count={clifford_count}\")"
   "execution_count": 26,
