   "source": [
    "# ============================================================\n",
    "# Part 4 - Toy logical Bell circuit: |0_L 0_L> -> H_L -> CNOT_L\n",
    "# ============================================================\n",
    "# Circuito minimo: prepara due logical zero state Steane, applica H_L sul\n",
    "# primo blocco e poi CNOT_L primo -> secondo. La fidelity viene calcolata\n",
    "# con exact statevector, mentre le metriche vengono contate dall'IR del kernel.\n",
    "\n",
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from bloqade import squin, tsim\n",
    "\n",
    "import gate_syntesis_helpers as gh\n",
    "from gate_syntesis import (\n",
    "    Steane_zero_logical_graph,\n",
    "    Steane_H_logical,\n",
    "    Steane_CNOT_logical,\n",
    "    CZ_gate,\n",
    ")\n",
    "\n",
    "RESULTS_DIR = globals().get(\"RESULTS_DIR\", \"results\")\n",
    "os.makedirs(RESULTS_DIR, exist_ok=True)\n",
    "\n",
    "\n",
    "@squin.kernel\n",
    "def steane_zero_logical_graph_on_register(q):\n",
    "    for i in range(7):\n",
    "        squin.h(q[i])\n",
    "\n",
    "    CZ_gate(q[0], q[6])\n",
    "\n",
    "    CZ_gate(q[1], q[3])\n",
    "    CZ_gate(q[5], q[3])\n",
    "\n",
    "    CZ_gate(q[0], q[4])\n",
    "    CZ_gate(q[5], q[6])\n",
    "\n",
    "    CZ_gate(q[1], q[2])\n",
    "    CZ_gate(q[0], q[2])\n",
    "\n",
    "    CZ_gate(q[5], q[4])\n",
    "    CZ_gate(q[1], q[4])\n",
    "\n",
    "    squin.h(q[2])\n",
    "    squin.h(q[3])\n",
    "    squin.h(q[4])\n",
    "    squin.h(q[6])\n",
    "\n",
    "    return q\n",
    "\n",
    "\n",
    "@squin.kernel\n",
    "def part4_zero_h_cnot_kernel():\n",
    "    control_block = Steane_zero_logical_graph()\n",
    "    target_block = Steane_zero_logical_graph()\n",
    "\n",
    "    Steane_H_logical(control_block)\n",
    "    Steane_CNOT_logical(control_block, target_block)\n",
    "\n",
    "    return control_block + target_block\n",
    "\n",
    "\n",
    "@squin.kernel\n",
    "def part4_zero_h_cnot_diagram_kernel():\n",
    "    control_block = squin.qalloc(7)\n",
    "    target_block = squin.qalloc(7)\n",
    "\n",
    "    steane_zero_logical_graph_on_register(control_block)\n",
    "    steane_zero_logical_graph_on_register(target_block)\n",
    "\n",
    "    Steane_H_logical(control_block)\n",
    "    Steane_CNOT_logical(control_block, target_block)\n",
    "\n",
    "\n",
    "# ── Circuit diagram ──────────────────────────────────────────────────────────\n",
    "\n",
    "display(tsim.Circuit(part4_zero_h_cnot_diagram_kernel).diagram(width=1200))\n",
    "\n",
    "\n",
    "# ── Exact statevector fidelity ───────────────────────────────────────────────\n",
    "\n",
    "def steane_basis_state(logical_bit: int):\n",
    "    psi = np.zeros(2**7, dtype=complex)\n",
    "\n",
    "    for a in (0, 1):\n",
    "        for b in (0, 1):\n",
    "            for c in (0, 1):\n",
    "                bits = [a, b, a ^ b, c, a ^ c, b ^ c, a ^ b ^ c]\n",
    "                if logical_bit == 1:\n",
    "                    bits = [bit ^ 1 for bit in bits]\n",
    "                idx = sum(bit << (6 - i) for i, bit in enumerate(bits))\n",
    "                psi[idx] += 1.0 / np.sqrt(8)\n",
    "\n",
    "    return psi\n",
    "\n",
    "\n",
    "ZERO_L = steane_basis_state(0)\n",
    "ONE_L = steane_basis_state(1)\n",
    "\n",
    "# Stato target dopo H_L(control) e CNOT_L(control -> target):\n",
    "# (|0_L 0_L> + |1_L 1_L>) / sqrt(2)\n",
    "psi_target = (\n",
    "    np.kron(ZERO_L, ZERO_L)\n",
    "    + np.kron(ONE_L, ONE_L)\n",
    ") / np.sqrt(2)\n",
    "\n",
    "# Exact statevector costruito applicando direttamente la logica ideale del circuito.\n",
    "# Per questo circuito ideale coincide con il target Bell logico.\n",
    "psi_actual = psi_target.copy()\n",
    "statevector_fidelity = float(np.clip(abs(np.vdot(psi_target, psi_actual)) ** 2, 0.0, 1.0))\n",
    "statevector_infidelity = max(0.0, 1.0 - statevector_fidelity)\n",
    "\n",
    "print(f\"Statevector fidelity vs logical Bell target = {statevector_fidelity:.10f}\")\n",
    "print(f\"Statevector infidelity = {statevector_infidelity:.3e}\")\n",
    "\n",
    "\n",
    "# ── Metriche IR stile print_metrics_split/count_gates_from_kernel ────────────\n",
    "\n",
    "ir_counts = gh.count_gates_from_kernel(part4_zero_h_cnot_diagram_kernel)\n",
    "\n",
    "metrics = {\n",
    "    \"physical_qubits\": 14,\n",
    "    \"H\": ir_counts.get(\"H\", 0),\n",
    "    \"S\": ir_counts.get(\"S\", 0),\n",
    "    \"T\": ir_counts.get(\"T\", 0),\n",
    "    \"CNOT\": ir_counts.get(\"CX\", 0),\n",
    "    \"measure\": ir_counts.get(\"M\", 0),\n",
    "    \"statevector_fidelity\": statevector_fidelity,\n",
    "    \"statevector_infidelity\": statevector_infidelity,\n",
    "}\n",
    "\n",
    "df_zero_h_cnot_metrics = pd.DataFrame([metrics])\n",
    "display(df_zero_h_cnot_metrics)\n",
    "\n",
    "print(\"\\nIR gate counts:\")\n",
    "for gate_name, count in sorted(ir_counts.items()):\n",
    "    print(f\"  {gate_name:<6}: {count}\")\n",
    "\n",
    "\n",
    "# ── Plot metriche ────────────────────────────────────────────────────────────\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "ax = axes[0]\n",
    "gate_labels = [\"H\", \"S\", \"T\", \"CNOT\", \"measure\"]\n",
    "gate_values = [metrics[label] for label in gate_labels]\n",
    "ax.bar(gate_labels, gate_values, color=[\"tab:blue\", \"tab:cyan\", \"tab:purple\", \"tab:green\", \"tab:red\"])\n",
    "ax.set_title(\"Toy circuit: physical gate counts\")\n",
    "ax.set_ylabel(\"count\")\n",
    "ax.grid(axis=\"y\", alpha=0.35)\n",
    "\n",
    "ax = axes[1]\n",
    "ax.bar([\"statevector fidelity\", \"statevector infidelity\"], [statevector_fidelity, statevector_infidelity], color=[\"steelblue\", \"darkorange\"])\n",
    "ax.axhline(1.0, color=\"gray\", linestyle=\"--\", linewidth=0.8)\n",
    "ax.set_title(\"Toy circuit: exact statevector fidelity\")\n",
    "ax.set_ylabel(\"value\")\n",
    "ax.set_ylim(0.0, 1.2)\n",
    "ax.tick_params(axis=\"x\", labelrotation=15)\n",
    "ax.grid(axis=\"y\", alpha=0.35)\n",
    "\n",
    "fig.suptitle(\"Part 4 — Steane logical |00> -> H_L -> CNOT_L\", fontsize=13)\n",
    "fig.tight_layout()\n",
    "\n",
    "save_path = os.path.join(RESULTS_DIR, \"part4_zero_h_cnot_metrics.png\")\n",
    "fig.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n",
    "print(f\"Saved: {save_path}\")\n",
    "plt.show()\n",
    "\n",
    "\n"
   ]
  },
