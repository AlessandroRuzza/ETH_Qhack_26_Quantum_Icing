   "source": [
    "# ============================================================\n",
    "# Part 4 - EXACT statevector fidelity\n",
    "#\n",
    "# Stessi grafici della cella sopra, ma usando aritmetica matriciale\n",
    "# esatta. La codifica Steane [[7,1,3]] è un'isometria, quindi la fidelity\n",
    "# nello spazio codificato 7-qubit (128 dim) coincide con quella a livello\n",
    "# logico 1-qubit. Il feed-forward del magic-state injection rende il\n",
    "# logical T esatto, quindi il risultato della \"Full Steane simulation\"\n",
    "# (esatta) deve coincidere con la \"Ideal logical prediction\".\n",
    "# ============================================================\n",
    "\n",
    "PART4_FIDELITY_N_VALUES = range(8)\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "import gate_syntesis_helpers as gh\n",
    "\n",
    "\n",
    "# Stati base Steane (riusati dalla cella sopra)\n",
    "ZERO_L_SV = steane_basis_state(0)\n",
    "ONE_L_SV  = steane_basis_state(1)\n",
    "\n",
    "\n",
    "def encode_logical_to_steane(psi_logical: np.ndarray) -> np.ndarray:\n",
    "    \"\"\"Encode a 1-qubit logical state into the 7-qubit Steane code subspace.\"\"\"\n",
    "    return psi_logical[0] * ZERO_L_SV + psi_logical[1] * ONE_L_SV\n",
    "\n",
    "\n",
    "def exact_steane_fidelity(theta: float, sequence) -> float:\n",
    "    \"\"\"Fidelity esatta nello spazio Steane 128-dim:\n",
    "       compara lo stato encoded prodotto dalla sequenza Clifford+T sintetizzata\n",
    "       contro lo stato encoded target Rz(theta)|+_L>.\"\"\"\n",
    "    psi_plus_logical = (gh.H @ np.array([1, 0], dtype=complex))   # = |+>\n",
    "\n",
    "    U_seq      = gh.unitary_from_gate_sequence(sequence)\n",
    "    psi_actual = encode_logical_to_steane(U_seq @ psi_plus_logical)\n",
    "    psi_target = encode_logical_to_steane(gh.Rz(theta) @ psi_plus_logical)\n",
    "\n",
    "    return float(np.clip(abs(np.vdot(psi_target, psi_actual)) ** 2, 0.0, 1.0))\n",
    "\n",
    "\n",
    "def exact_logical_fidelity(theta: float, sequence) -> float:\n",
    "    \"\"\"Fidelity a livello single-qubit (2-dim) — equivalente per isometria.\"\"\"\n",
    "    psi_plus = (gh.H @ np.array([1, 0], dtype=complex))\n",
    "    psi_actual = gh.unitary_from_gate_sequence(sequence) @ psi_plus\n",
    "    psi_target = gh.Rz(theta) @ psi_plus\n",
    "    return float(np.clip(abs(np.vdot(psi_target, psi_actual)) ** 2, 0.0, 1.0))\n",
    "\n",
    "\n",
    "# ── Calcolo esatto per ogni n ─────────────────────────────────────────────────\n",
    "\n",
    "rows_sv = []\n",
    "for n in PART4_FIDELITY_N_VALUES:\n",
    "    theta    = np.pi / (2 ** n)\n",
    "    sequence = get_part4_sequence(n)\n",
    "    t_count  = gh.t_count_from_sequence(sequence)\n",
    "\n",
    "    f_steane_exact = exact_steane_fidelity(theta, sequence)\n",
    "    f_ideal_exact  = exact_logical_fidelity(theta, sequence)\n",
    "\n",
    "    clifford_count = len(sequence) - t_count\n",
    "\n",
    "    rows_sv.append({\n",
    "        \"n\":                              n,\n",
    "        \"T_count\":                        t_count,\n",
    "        \"Clifford_count\":                 clifford_count,\n",
    "        \"Rz_sequence\":                    \" \".join(sequence).upper(),\n",
    "        \"steane_fidelity_exact\":          f_steane_exact,\n",
    "        \"ideal_logical_fidelity_exact\":   f_ideal_exact,\n",
    "        \"steane_infidelity_exact\":        max(0.0, 1.0 - f_steane_exact),\n",
    "        \"ideal_logical_infidelity_exact\": max(0.0, 1.0 - f_ideal_exact),\n",
    "    })\n",
    "\n",
    "df_part4_sv = pd.DataFrame(rows_sv)\n",
    "\n",
    "print(f\"{'n':>3}  {'T-count':>7}  {'Clifford':>8}  {'Steane statevector fidelity':>18}  {'Ideal statevector fidelity':>18}  {'Δ (Steane − ideal)':>22}\")\n",
    "print(\"-\" * 92)\n",
    "for r in rows_sv:\n",
    "    delta = r[\"steane_fidelity_exact\"] - r[\"ideal_logical_fidelity_exact\"]\n",
    "    print(f\"{r['n']:>3}  {r['T_count']:>7}  {r['Clifford_count']:>8}  \"\n",
    "          f\"{r['steane_fidelity_exact']:>18.15f}  \"\n",
    "          f\"{r['ideal_logical_fidelity_exact']:>18.15f}  \"\n",
    "          f\"{delta:>+22.3e}\")\n",
    "\n",
    "display(df_part4_sv[[\n",
    "    \"n\", \"T_count\", \"Clifford_count\",\n",
    "    \"steane_fidelity_exact\", \"ideal_logical_fidelity_exact\",\n",
    "    \"steane_infidelity_exact\", \"ideal_logical_infidelity_exact\",\n",
    "]])\n",
    "\n",
    "\n",
    "# ── Plot 1: statevector fidelity ──────────────────────────────────────────────────────────\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "ax.plot(df_part4_sv[\"n\"], df_part4_sv[\"steane_fidelity_exact\"],\n",
    "        marker=\"o\", linewidth=1.6, label=\"Full Steane simulation (exact)\")\n",
    "ax.plot(df_part4_sv[\"n\"], df_part4_sv[\"ideal_logical_fidelity_exact\"],\n",
    "        marker=\"s\", linestyle=\"--\", label=\"Ideal logical prediction\")\n",
    "ax.set_xlabel(\"n\")\n",
    "ax.set_ylabel(\"Statevector fidelity\")\n",
    "ax.set_title(\"Part 4: statevector fidelity — exact statevector\")\n",
    "ax.set_xticks(list(PART4_FIDELITY_N_VALUES))\n",
    "ax.set_ylim(0.5, 1.2)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "\n",
    "# ── Plot 2: statevector infidelity log-scale ──────────────────────────────────────────────\n",
    "\n",
    "steane_inf = df_part4_sv[\"steane_infidelity_exact\"].replace(0.0, np.nan)\n",
    "ideal_inf  = df_part4_sv[\"ideal_logical_infidelity_exact\"].replace(0.0, np.nan)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "ax.semilogy(df_part4_sv[\"n\"], steane_inf,\n",
    "            marker=\"o\", linewidth=1.6, label=\"Full Steane simulation (exact)\")\n",
    "ax.semilogy(df_part4_sv[\"n\"], ideal_inf,\n",
    "            marker=\"s\", linestyle=\"--\", label=\"Ideal logical prediction\")\n",
    "ax.set_xlabel(\"n\")\n",
    "ax.set_ylabel(\"Statevector infidelity 1 − F\")\n",
    "ax.set_title(\"Part 4: statevector infidelity — exact statevector\")\n",
    "ax.set_xticks(list(PART4_FIDELITY_N_VALUES))\n",
    "ax.set_ylim(top=1.2)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "fig.tight_layout()\n",
    "plt.show()\n"
   ]
  },
