   "source": [
    "# ============================================================\n",
    "# Team Synthesis - Part 3\n",
    "# Postselection dropout without feed-forward S correction\n",
    "# ============================================================\n",
    "\n",
    "import os, sys, importlib\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "sys.path.insert(0, os.path.dirname(os.path.abspath(\"syntesis_1_2.py\")))\n",
    "\n",
    "import syntesis_1_2\n",
    "importlib.reload(syntesis_1_2)\n",
    "\n",
    "from bloqade.pyqrack import StackMemorySimulator\n",
    "from syntesis_1_2 import make_postselected_dropout_kernel, t_count_from_sequence\n",
    "\n",
    "if \"N_VALUES\" not in globals():\n",
    "    N_VALUES = range(51)\n",
    "\n",
    "if \"PART2_EPSILON\" not in globals():\n",
    "    PART2_EPSILON = 1e-10\n",
    "\n",
    "if \"part2_circuits\" not in globals() or \"part2_sequences\" not in globals():\n",
    "    import syntesis_part3\n",
    "    importlib.reload(syntesis_part3)\n",
    "    part2_circuits, part2_sequences = syntesis_part3.ensure_part2_results(\n",
    "        n_values=N_VALUES,\n",
    "        part2_epsilon=PART2_EPSILON,\n",
    "    )\n",
    "\n",
    "# Exact dropout from postselection: keep only shots where every injection measures 0.\n",
    "dropout_rows = []\n",
    "for n in N_VALUES:\n",
    "    t_count = t_count_from_sequence(part2_sequences[n])\n",
    "    success_probability = 2 ** (-t_count)\n",
    "    dropout_rows.append(\n",
    "        {\n",
    "            \"n\": n,\n",
    "            \"logical_T_count\": t_count,\n",
    "            \"postselection_success_probability_exact\": success_probability,\n",
    "            \"dropout_probability_exact\": 1 - success_probability,\n",
    "        }\n",
    "    )\n",
    "\n",
    "df_part3_dropout = pd.DataFrame(dropout_rows)\n",
    "display(df_part3_dropout)\n",
    "\n",
    "# Tutorial-style shot estimate for small cases only. The kernel returns 1 when\n",
    "# at least one ancilla measurement is 1; no conditional S correction is applied.\n",
    "DROPOUT_SIM_SHOTS = 200\n",
    "MAX_SIMULATED_T_COUNT = 2\n",
    "simulated_rows = []\n",
    "for _, row in df_part3_dropout.iterrows():\n",
    "    n = int(row[\"n\"])\n",
    "    t_count = int(row[\"logical_T_count\"])\n",
    "\n",
    "    if t_count == 0:\n",
    "        simulated_rows.append(\n",
    "            {\n",
    "                \"n\": n,\n",
    "                \"logical_T_count\": t_count,\n",
    "                \"shots\": 0,\n",
    "                \"dropout_rate_estimated\": 0.0,\n",
    "            }\n",
    "        )\n",
    "        continue\n",
    "\n",
    "    if t_count > MAX_SIMULATED_T_COUNT:\n",
    "        continue\n",
    "\n",
    "    kernel = make_postselected_dropout_kernel(part2_sequences[n])\n",
    "    task = StackMemorySimulator(min_qubits=1 + t_count).task(kernel)\n",
    "    dropouts = sum(int(task.run()) for _ in range(DROPOUT_SIM_SHOTS))\n",
    "    simulated_rows.append(\n",
    "        {\n",
    "            \"n\": n,\n",
    "            \"logical_T_count\": t_count,\n",
    "            \"shots\": DROPOUT_SIM_SHOTS,\n",
    "            \"dropout_rate_estimated\": dropouts / DROPOUT_SIM_SHOTS,\n",
    "        }\n",
    "    )\n",
    "\n",
    "df_part3_dropout_simulated = pd.DataFrame(simulated_rows)\n",
    "display(df_part3_dropout_simulated)\n",
    "\n",
    "RESULTS_DIR = globals().get(\"RESULTS_DIR\", \"results\")\n",
    "os.makedirs(RESULTS_DIR, exist_ok=True)\n",
    "\n",
    "plt.figure(figsize=(7, 4))\n",
    "plt.plot(\n",
    "    df_part3_dropout[\"n\"],\n",
    "    df_part3_dropout[\"dropout_probability_exact\"],\n",
    "    marker=\"o\",\n",
    "    label=\"Exact dropout\",\n",
    ")\n",
    "if not df_part3_dropout_simulated.empty:\n",
    "    estimated = df_part3_dropout_simulated[df_part3_dropout_simulated[\"shots\"] > 0]\n",
    "    plt.scatter(\n",
    "        estimated[\"n\"],\n",
    "        estimated[\"dropout_rate_estimated\"],\n",
    "        marker=\"x\",\n",
    "        label=\"Shot estimate\",\n",
    "    )\n",
    "plt.xlabel(\"n\")\n",
    "plt.ylabel(\"Dropout probability\")\n",
    "plt.title(\"Part 3: postselection dropout without feed-forward\")\n",
    "plt.xticks(df_part3_dropout[\"n\"])\n",
    "plt.ylim(-0.05, 1.05)\n",
    "plt.legend()\n",
    "plt.grid(True)\n",
    "plt.tight_layout()\n",
    "plt.savefig(\n",
    "    os.path.join(RESULTS_DIR, \"part3_postselection_dropout_probability.png\"),\n",
    "    dpi=300,\n",
    "    bbox_inches=\"tight\",\n",
    ")\n",
    "plt.show()\n"
   ]
