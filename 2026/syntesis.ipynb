   "source": [
    "# ============================================================\n",
    "# Part 4 — Rz_L(π/2^n) con Steane_apply_logical_gate_sequence_reuse_magic\n",
    "#           epsilon = 1e-10, magic block singolo riusabile\n",
    "# ============================================================\n",
    "# Exact statevector version: stessa sequenza Clifford+T della reuse-magic,\n",
    "# ma fidelity calcolata esattamente nello spazio codificato Steane.\n",
    "\n",
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from qiskit.synthesis import gridsynth_rz\n",
    "\n",
    "import gate_syntesis_helpers as gh\n",
    "from gate_syntesis import (\n",
    "    make_part4_logical_fidelity_kernel_reuse_magic,\n",
    "    part4_logical_fidelity_qubit_count,\n",
    ")\n",
    "\n",
    "EPSILON_10 = 1e-10\n",
    "N_REUSE    = range(8)   # cambia il range a piacere\n",
    "RESULTS_DIR = globals().get(\"RESULTS_DIR\", \"results\")\n",
    "os.makedirs(RESULTS_DIR, exist_ok=True)\n",
    "\n",
    "\n",
    "# ── sequenza Part 2 / reuse magic ────────────────────────────────────────────\n",
    "\n",
    "def _seq(n, eps=EPSILON_10):\n",
    "    if n == 0: return (\"s\", \"s\")\n",
    "    if n == 1: return (\"s\",)\n",
    "    if n == 2: return (\"t\",)\n",
    "    return gh.gate_sequence_from_circuit(gridsynth_rz(np.pi / 2**n, epsilon=eps))\n",
    "\n",
    "\n",
    "def _reuse_magic_qubit_count(sequence):\n",
    "    return 14 if gh.t_count_from_sequence(sequence) else 7\n",
    "\n",
    "\n",
    "def get_part4_sequence(n: int):\n",
    "    return _seq(n, EPSILON_10)\n",
    "\n",
    "\n",
    "# ── Steane basis states per exact statevector fidelity ───────────────────────\n",
    "\n",
    "def _steane_basis(logical_bit):\n",
    "    psi = np.zeros(2**7, dtype=complex)\n",
    "    for a in (0, 1):\n",
    "        for b in (0, 1):\n",
    "            for c in (0, 1):\n",
    "                bits = [a, b, a^b, c, a^c, b^c, a^b^c]\n",
    "                if logical_bit == 1:\n",
    "                    bits = [x ^ 1 for x in bits]\n",
    "                idx = sum(bit << (6 - i) for i, bit in enumerate(bits))\n",
    "                psi[idx] += 1.0 / np.sqrt(8)\n",
    "    return psi\n",
    "\n",
    "\n",
    "_ZERO_L = _steane_basis(0)\n",
    "_ONE_L  = _steane_basis(1)\n",
    "\n",
    "# Names kept for the exact-statevector cell below.\n",
    "ZERO_L = _ZERO_L\n",
    "ONE_L = _ONE_L\n",
    "\n",
    "def steane_basis_state(logical_bit: int):\n",
    "    return _steane_basis(logical_bit)\n",
    "\n",
    "\n",
    "def _encode_logical_to_steane(psi_logical):\n",
    "    return psi_logical[0] * _ZERO_L + psi_logical[1] * _ONE_L\n",
    "\n",
    "\n",
    "def _exact_steane_statevector_fidelity(theta, sequence):\n",
    "    psi_plus = gh.H @ np.array([1, 0], dtype=complex)\n",
    "    psi_actual = _encode_logical_to_steane(gh.unitary_from_gate_sequence(sequence) @ psi_plus)\n",
    "    psi_target = _encode_logical_to_steane(gh.Rz(theta) @ psi_plus)\n",
    "    return float(np.clip(abs(np.vdot(psi_target, psi_actual)) ** 2, 0.0, 1.0))\n",
    "\n",
    "\n",
    "def _exact_logical_statevector_fidelity(theta, sequence):\n",
    "    psi_plus = gh.H @ np.array([1, 0], dtype=complex)\n",
    "    psi_actual = gh.unitary_from_gate_sequence(sequence) @ psi_plus\n",
    "    psi_target = gh.Rz(theta) @ psi_plus\n",
    "    return float(np.clip(abs(np.vdot(psi_target, psi_actual)) ** 2, 0.0, 1.0))\n",
    "\n",
    "\n",
    "# ── exact statevector calculation ────────────────────────────────────────────\n",
    "\n",
    "rows = []\n",
    "\n",
    "for n in N_REUSE:\n",
    "    theta    = np.pi / (2**n)\n",
    "    sequence = _seq(n, EPSILON_10)\n",
    "    t_count  = gh.t_count_from_sequence(sequence)\n",
    "    clifford_count = len(sequence) - t_count\n",
    "    n_qubits = _reuse_magic_qubit_count(sequence)\n",
    "\n",
    "    seq_str = \" \".join(sequence).upper()\n",
    "    steane_fidelity = _exact_steane_statevector_fidelity(theta, sequence)\n",
    "    ideal_fidelity  = _exact_logical_statevector_fidelity(theta, sequence)\n",
    "\n",
    "    rows.append({\n",
    "        \"n\": n,\n",
    "        \"sequence\": seq_str,\n",
    "        \"T_count\": t_count,\n",
    "        \"Clifford_count\": clifford_count,\n",
    "        \"phys_qubits\": n_qubits,\n",
    "        \"steane_statevector_fidelity\": steane_fidelity,\n",
    "        \"ideal_statevector_fidelity\": ideal_fidelity,\n",
    "        \"steane_statevector_infidelity\": max(0.0, 1.0 - steane_fidelity),\n",
    "        \"ideal_statevector_infidelity\": max(0.0, 1.0 - ideal_fidelity),\n",
    "    })\n",
    "\n",
    "    delta = steane_fidelity - ideal_fidelity\n",
    "    print(\n",
    "        f\"n={n}  T-count={t_count:3d}  Clifford={clifford_count:3d}  \"\n",
    "        f\"Steane statevector fidelity={steane_fidelity:.10f}  \"\n",
    "        f\"Ideal={ideal_fidelity:.10f}  Δ={delta:+.3e}\"\n",
    "    )\n",
    "\n",
    "\n",
    "df_reuse = pd.DataFrame(rows)\n",
    "\n",
    "# ── Metriche tabellari ───────────────────────────────────────────────────────\n",
    "\n",
    "print()\n",
    "print(f\"{'n':>3}  {'T-count':>7}  {'Clifford':>8}  {'phys_qubits':>11}  {'Steane statevector fidelity':>28}  {'Ideal statevector fidelity':>28}  {'Delta':>12}\")\n",
    "print(\"-\" * 112)\n",
    "for r in rows:\n",
    "    delta = r[\"steane_statevector_fidelity\"] - r[\"ideal_statevector_fidelity\"]\n",
    "    print(\n",
    "        f\"{r['n']:>3}  {r['T_count']:>7}  {r['Clifford_count']:>8}  {r['phys_qubits']:>11}  \"\n",
    "        f\"{r['steane_statevector_fidelity']:>28.10f}  \"\n",
    "        f\"{r['ideal_statevector_fidelity']:>28.10f}  \"\n",
    "        f\"{delta:>+12.3e}\"\n",
    "    )\n",
    "\n",
    "display(df_reuse[[\n",
    "    \"n\", \"T_count\", \"Clifford_count\", \"phys_qubits\",\n",
    "    \"steane_statevector_fidelity\", \"ideal_statevector_fidelity\",\n",
    "    \"steane_statevector_infidelity\", \"ideal_statevector_infidelity\",\n",
    "]])\n",
    "\n",
    "# ── Gate-count plot stile plot.plot_gate_counts(...) ─────────────────────────\n",
    "\n",
    "GATE_COUNT_N_VALUES = range(20)\n",
    "GATE_COUNT_EPSILON = 1e-20\n",
    "\n",
    "gate_count_rows = []\n",
    "for n in GATE_COUNT_N_VALUES:\n",
    "    sequence = _seq(n, GATE_COUNT_EPSILON)\n",
    "    t_count = gh.t_count_from_sequence(sequence)\n",
    "    clifford_count = len(sequence) - t_count\n",
    "\n",
    "    reuse_kernel = make_part4_logical_fidelity_kernel_reuse_magic(sequence)\n",
    "    ir_counts = gh.count_gates_from_kernel(reuse_kernel)  # same IR counter used by print_metrics_split\n",
    "\n",
    "    gate_count_rows.append({\n",
    "        \"n\": n,\n",
    "        \"T_count\": t_count,\n",
    "        \"Clifford_count\": clifford_count,\n",
    "        \"phys_qubits_reuse_magic\": part4_logical_fidelity_qubit_count(sequence),\n",
    "        \"physical_CNOT_count\": ir_counts.get(\"CX\", 0),\n",
    "        \"physical_H_count\": ir_counts.get(\"H\", 0),\n",
    "        \"physical_S_count\": ir_counts.get(\"S\", 0),\n",
    "        \"physical_T_count\": ir_counts.get(\"T\", 0),\n",
    "        \"measure_count\": ir_counts.get(\"M\", 0),\n",
    "    })\n",
    "\n",
    "df_part4_gate_counts = pd.DataFrame(gate_count_rows)\n",
    "display(df_part4_gate_counts)\n",
    "\n",
    "ns_gc = df_part4_gate_counts[\"n\"].tolist()\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "ax = axes[0]\n",
    "ax.plot(ns_gc, df_part4_gate_counts[\"Clifford_count\"], marker=\"o\", label=\"Clifford\")\n",
    "ax.plot(ns_gc, df_part4_gate_counts[\"T_count\"], marker=\"s\", linestyle=\"--\", label=\"T/Tdg\")\n",
    "ax.set_title(\"Part 4: Clifford+T sequence counts\")\n",
    "ax.set_xlabel(\"n\")\n",
    "ax.set_ylabel(\"count\")\n",
    "ax.set_xticks(ns_gc)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "\n",
    "ax = axes[1]\n",
    "ax.plot(ns_gc, df_part4_gate_counts[\"physical_CNOT_count\"], marker=\"o\", color=\"tab:green\", label=\"physical CNOT count\")\n",
    "ax.plot(ns_gc, df_part4_gate_counts[\"phys_qubits_reuse_magic\"], marker=\"s\", linestyle=\"--\", color=\"tab:red\", label=\"physical qubits\")\n",
    "ax.set_title(\"Part 4: reuse-magic resources\")\n",
    "ax.set_xlabel(\"n\")\n",
    "ax.set_ylabel(\"count\")\n",
    "ax.set_xticks(ns_gc)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "\n",
    "fig.suptitle(f\"Part 4 — reuse-magic gate counts  (ε={GATE_COUNT_EPSILON})\", fontsize=13)\n",
    "fig.tight_layout()\n",
    "\n",
    "gate_counts_path = os.path.join(RESULTS_DIR, \"part4_reuse_magic_gate_counts.png\")\n",
    "fig.savefig(gate_counts_path, dpi=300, bbox_inches=\"tight\")\n",
    "print(f\"Saved: {gate_counts_path}\")\n",
    "plt.show()\n",
    "\n",
    "# ── Plot statevector fidelity e infidelity ───────────────────────────────────\n",
    "\n",
    "ns = df_reuse[\"n\"].tolist()\n",
    "steane_fidelities = df_reuse[\"steane_statevector_fidelity\"].tolist()\n",
    "ideal_fidelities = df_reuse[\"ideal_statevector_fidelity\"].tolist()\n",
    "steane_infidels = df_reuse[\"steane_statevector_infidelity\"].clip(lower=1e-18).tolist()\n",
    "ideal_infidels = df_reuse[\"ideal_statevector_infidelity\"].clip(lower=1e-18).tolist()\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
    "\n",
    "ax = axes[0]\n",
    "ax.plot(ns, steane_fidelities, marker=\"o\", color=\"steelblue\", label=\"Steane reuse magic (exact statevector)\")\n",
    "ax.plot(ns, ideal_fidelities, marker=\"s\", color=\"darkorange\", linestyle=\"--\", label=\"Ideal logical statevector\")\n",
    "ax.axhline(1.0, color=\"gray\", linestyle=\"--\", linewidth=0.8)\n",
    "ax.set_xlabel(\"n\")\n",
    "ax.set_ylabel(\"Statevector fidelity\")\n",
    "ax.set_title(\"Part 4: statevector fidelity  Rz_L(π/2ⁿ)|+_L⟩  (reuse magic)\")\n",
    "ax.set_xticks(ns)\n",
    "ax.ticklabel_format(axis=\"y\", style=\"plain\", useOffset=False)\n",
    "ax.yaxis.set_major_formatter(plt.FormatStrFormatter(\"%.7f\"))\n",
    "ax.set_ylim(0.5, 1.2)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "\n",
    "ax = axes[1]\n",
    "ax.semilogy(ns, steane_infidels, marker=\"o\", color=\"steelblue\", label=\"Steane reuse magic (exact statevector)\")\n",
    "ax.semilogy(ns, ideal_infidels, marker=\"s\", color=\"darkorange\", linestyle=\"--\", label=\"Ideal logical statevector\")\n",
    "ax.set_xlabel(\"n\")\n",
    "ax.set_ylabel(\"Statevector infidelity  1 − F\")\n",
    "ax.set_title(\"Part 4: statevector infidelity  (log scale)\")\n",
    "ax.set_xticks(ns)\n",
    "ax.set_ylim(top=1.2)\n",
    "ax.legend()\n",
    "ax.grid(True)\n",
    "\n",
    "fig.suptitle(f\"Part 4 — Steane [[7,1,3]] exact statevector fidelity  (ε={EPSILON_10})\", fontsize=13)\n",
    "fig.tight_layout()\n",
    "\n",
    "save_path = os.path.join(RESULTS_DIR, \"part4_reuse_magic_fidelity.png\")\n",
    "fig.savefig(save_path, dpi=300, bbox_inches=\"tight\")\n",
    "print(f\"\\nSaved: {save_path}\")\n",
    "plt.show()\n"
   ]
  },
